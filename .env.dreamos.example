# Copy to `.env.dreamos` in this repository root (loaded automatically before Settings).
# Does not override variables already set in the environment.
# Use the directory that contains your cloned repos as immediate children (or set to a single repo root).
# Example: D:\ if each repo is D:\RepoName\.git
DREAMOS_GITHUB_DIR=D:/
DREAMOS_SAFE_REPOS=Dream.os-Core,projectscanner,Agent_Cellphone
